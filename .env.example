# Blockradar API credentials
# Get these from your Blockradar dashboard after creating a master wallet
BLOCKRADAR_API_KEY=your_api_key_here
BLOCKRADAR_WALLET_ID=your_wallet_id_here
BLOCKRADAR_SECRET_KEY=your_secret_key_here

# Base URL (don't change)
BLOCKRADAR_BASE_URL=https://api.blockradar.co/v1

# Your app URL (update when deployed)
NEXT_PUBLIC_APP_URL=http://localhost:3000
